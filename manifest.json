{
  "manifest_version": 3,
  "name": "YouTube Playlist Search",
  "version": "1.0.6",
  "description": "Search videos within YouTube playlists",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": {
      "16": "icons/yt-playlist-icon-dark-16.png",
      "32": "icons/yt-playlist-icon-dark-32.png",
      "48": "icons/yt-playlist-icon-dark-48.png",
      "64": "icons/yt-playlist-icon-dark-64.png",
      "128": "icons/yt-playlist-icon-dark-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "common.js",
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-playlist-search-ext@mrpanda009.github.io",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "icons": {
    "16": "icons/yt-playlist-icon-dark-16.png",
    "32": "icons/yt-playlist-icon-dark-32.png",
    "48": "icons/yt-playlist-icon-dark-48.png",
    "64": "icons/yt-playlist-icon-dark-64.png",
    "128": "icons/yt-playlist-icon-dark-128.png"
  }
}