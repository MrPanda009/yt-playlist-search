{
  "manifest_version": 3,
  "name": "YouTube Playlist Search",
  "version": "1.0",
  "description": "Search videos within YouTube playlists",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": {
      "16": "icons/yt-playlist-icon-dark.png",
      "32": "icons/yt-playlist-icon-dark.png",
      "48": "icons/yt-playlist-icon-dark.png",
      "128": "icons/yt-playlist-icon-dark.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/playlist*",
        "https://www.youtube.com/watch*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-playlist-search@mrpanda009.github.io"
    }
  },
  "icons": {
    "16": "icons/yt-playlist-icon-dark.png",
    "32": "icons/yt-playlist-icon-dark.png",
    "48": "icons/yt-playlist-icon-dark.png",
    "128": "icons/yt-playlist-icon-dark.png"
  }
}